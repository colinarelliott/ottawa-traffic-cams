# Required: generate with: openssl rand -hex 32
API_SECRET=replace_with_output_of_openssl_rand_hex_32

# Comma-separated list of allowed CORS origins.
# For local dev include the Vite dev server; in production use only your Vercel URL.
ALLOWED_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Where to store captured frames and encoded videos
FRAMES_DIR=./data/frames
VIDEOS_DIR=./data/videos

# Port the Express server listens on
PORT=3001

# Output framerate for timelapse MP4s
# 16 cameras × every 5s × 24h = 17,280 frames/camera
# At 30fps that's a ~9.6 minute timelapse per camera per day
TIMELAPSE_FPS=30

# How many days of encoded videos to keep (older videos are deleted at 00:05)
RETAIN_DAYS=5
